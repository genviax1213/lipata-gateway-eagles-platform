<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep real files/directories served directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Do not rewrite API/auth endpoints that should be handled by Laravel.
  RewriteCond %{REQUEST_URI} ^/api/ [OR]
  RewriteCond %{REQUEST_URI} ^/sanctum/
  RewriteRule ^ - [L]

  # SPA fallback for React Router (BrowserRouter).
  RewriteRule ^ index.html [L]
</IfModule>
